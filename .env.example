AUTH_SECRET=change-me-use-openssl-rand-base64-32
AUTH_URL=http://localhost:3011
NEXTAUTH_URL=http://localhost:3011
AUTH_TRUST_HOST=true
NEXT_PUBLIC_APP_URL=http://localhost:3011

# Local development: install PostgreSQL and create database, or use Docker:
#   docker run -d --name scamshield-pg -e POSTGRES_PASSWORD=local -e POSTGRES_DB=scamshield -p 5432:5432 postgres:16
DATABASE_URL=postgresql://postgres:local@localhost:5432/scamshield

# Production on Render: DATABASE_URL is auto-set by render.yaml from the PostgreSQL service
